# Root .gitignore for monorepo with separate projects

# Dependencies
node_modules/
package-lock.json
pnpm-lock.yaml

# Environment variables
.env
.env.local
.env.*.local

# IDE & Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# OS
Thumbs.db

# Build outputs
dist/
build/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed

# Coverage
coverage/
.nyc_output/

# Temporary files
tmp/
temp/
